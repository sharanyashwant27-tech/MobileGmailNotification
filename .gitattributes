# Normalize line endings to LF in the repo; check out native on each OS.
* text=auto eol=lf

# Explicit LF for source and config files (avoids CRLF churn on Windows).
*.go        text eol=lf
*.mod       text eol=lf
*.sum       text eol=lf
*.dart      text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.gradle    text eol=lf
*.kt        text eol=lf
*.xml       text eol=lf
*.properties text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# Treat these as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
